<article class="archive-article archive-type-<%= post.layout %>">
  <div class="archive-article-inner">
    <header class="archive-article-header">
      <%- partial('post/date', {class_name: 'archive-article-date', date_format: 'MMM D'}) %>
      <%- partial('post/title', {class_name: 'archive-article-title', index: true}) %>
      <% if (post.excerpt){ %>
        <div class="archive-article-excerpt"><%- post.excerpt %></div>
      <% } else if (post.description){ %>
        <div class="archive-article-excerpt"><%= post.description %></div>
      <% } %>
    </header>
  </div>
</article>