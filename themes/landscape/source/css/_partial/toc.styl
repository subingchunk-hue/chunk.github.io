// 左侧浮动目录样式
.toc-sidebar
  position: fixed
  top: 80px
  left: 0
  width: 260px
  max-height: calc(100vh - 100px)
  z-index: 100
  transition: transform 0.3s ease

  &.toc-sidebar-hidden
    .toc-sidebar-inner
      display: none
    .toc-sidebar-show
      display: flex

.toc-sidebar-inner
  background: rgba(255, 255, 255, 0.95)
  border: 1px solid rgba(64, 224, 208, 0.3)
  border-radius: 0 12px 12px 0
  margin-left: 0
  display: flex
  flex-direction: column
  max-height: calc(100vh - 100px)

.toc-sidebar-header
  display: flex
  align-items: center
  justify-content: space-between
  padding: 12px 16px
  border-bottom: 1px solid rgba(64, 224, 208, 0.2)
  background: rgba(64, 224, 208, 0.08)

.toc-sidebar-title
  font-weight: 600
  font-size: 15px
  color: #333
  i
    margin-right: 8px
    color: #008B8B

.toc-sidebar-toggle
  background: none
  border: none
  cursor: pointer
  padding: 4px 8px
  color: #666
  border-radius: 4px
  transition: all 0.2s
  &:hover
    color: #008B8B
    background: rgba(64, 224, 208, 0.1)

.toc-sidebar-content
  padding: 10px 12px
  overflow-y: auto
  flex: 1

.toc-sidebar-show
  display: none
  position: fixed
  top: 80px
  left: 0
  width: 40px
  height: 40px
  background: rgba(255, 255, 255, 0.95)
  border: 1px solid rgba(64, 224, 208, 0.3)
  border-radius: 0 8px 8px 0
  align-items: center
  justify-content: center
  cursor: pointer
  color: #008B8B
  font-size: 18px
  z-index: 100
  &:hover
    background: rgba(64, 224, 208, 0.15)

// 目录列表
.toc-list
  list-style: none
  margin: 0
  padding: 0

  .toc-item
    position: relative
    display: flex
    align-items: flex-start
    flex-wrap: wrap
    padding: 2px 0

    a
      display: block
      padding: 3px 4px
      color: #555
      text-decoration: none
      font-size: 14px
      line-height: 1.4
      flex: 1
      transition: color 0.2s
      &:hover
        color: #008B8B
        text-decoration: none

  // 嵌套子级缩进
  ul
    list-style: none
    margin: 0
    padding-left: 16px
    width: 100%
    &.toc-collapsed
      display: none

// 折叠箭头
.toc-arrow
  display: inline-flex
  align-items: center
  justify-content: center
  width: 16px
  height: 22px
  cursor: pointer
  color: #999
  flex-shrink: 0
  font-size: 14px
  &:hover
    color: #008B8B

.toc-arrow-placeholder
  display: inline-block
  width: 16px
  flex-shrink: 0

// 滚动条样式
.toc-sidebar-content
  &::-webkit-scrollbar
    width: 6px
  &::-webkit-scrollbar-thumb
    background: rgba(64, 224, 208, 0.3)
    border-radius: 3px
  &::-webkit-scrollbar-track
    background: transparent

// 响应式：移动端隐藏左侧目录
@media (max-width: 1024px)
  .toc-sidebar
    display: none
